<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PersonalWebsite.styles.css" asp-append-version="true" />
</head>
<body>
    <nav class="side-nav" aria-label="Primary navigation">
        <a class="nav-brand" asp-controller="Home" asp-action="Index" aria-label="Home">
            <i class="fas fa-home" aria-hidden="true"></i>
        </a>
        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : null)" asp-controller="Home" asp-action="Index">Home</a>
        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Faq" ? "active" : null)" asp-controller="Faq" asp-action="Index">FAQ</a>
        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Gaming" ? "active" : null)" asp-controller="Gaming" asp-action="Index">Gaming with Me</a>
        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Blog" ? "active" : null)" asp-controller="Blog" asp-action="Index">Blog</a>
    </nav>

    <div class="container">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
